{
  "id": "dps-veterans-in-custody-by-establishment-report",
  "name": "DPS report on veterans in custody by establishment",
  "description": "This report lists the veterans currently in custody in one or more of the users caseloads, including their status and relevant details.",
  "metadata": {
    "version": "1.0.0"
  },
  "datasource": [
    {
      "id": "datamart",
      "name": "datamart"
    }
  ],
  "dataset": [
    {
      "id": "dps-veterans-in-custody-by-establishment",
      "name": "Veterans in Custody by Establishment",
      "description": "Veterans",
      "datasource": "datamart",
      "query": "SELECT offr.offender_id_display AS prisoner_number, offr.first_name AS first_name, offr.last_name AS last_name, offr.birth_date AS dob, date_diff('year', offr.birth_date, current_date) - CASE WHEN to_char(current_date, 'MMDD') < to_char(birth_date, 'MMDD') THEN 1 ELSE 0 END AS age, off_gen.description AS gender, off_eth.description AS ethnicity, CASE WHEN off_eth.code IN ('W2','W1','W9','W8','W10','W3') THEN 'White' WHEN off_eth.code IN ('O2','A4','O1','M9','M2','B9','B1','A3','A1','O9','M3','M1','B2','A9','A2') THEN 'BAME' WHEN off_eth.code = 'NS' THEN 'Not Stated' END AS grouped_ethnicity, off_loc.description AS prison, off_loc.agy_loc_id AS prison_code, CASE WHEN off_loc.agy_loc_id IN ('AGI','BZI','DHI','DWI','ESI','EWI','FHI','LNI','NHI','PFI','SDI','STI') THEN 'Female' ELSE off_reg.description END AS region, CASE WHEN off_mr.military_seq IS NOT NULL THEN 'Y' ELSE 'N' END AS has_military_record, CASE WHEN off_al.alert_code IS NOT NULL THEN 'Y' ELSE 'N' END AS has_veteran_flag, off_mr.service_number, CASE WHEN REGEXP_COUNT(off_mr.service_number, '^([0-9]{8}|[A-Za-z][0-9]{7}|[A-Za-z][0-9]{6}[A-Za-z])$') = 1 THEN 'Y' ELSE 'N' END AS valid_service_number FROM datamart.prisons.nomis_offenders offr INNER JOIN datamart.prisons.nomis_offender_bookings off_bk ON offr.offender_id = off_bk.offender_id AND off_bk.active_flag = 'Y' INNER JOIN datamart.prisons.nomis_agency_locations off_loc ON off_bk.agy_loc_id = off_loc.agy_loc_id AND off_loc.agency_location_type = 'INST' LEFT JOIN datamart.prisons.nomis_offender_military_records off_mr ON off_bk.offender_book_id = off_mr.offender_book_id LEFT JOIN datamart.prisons.nomis_offender_alerts off_al ON off_al.offender_book_id = off_bk.offender_book_id AND off_al.alert_status = 'ACTIVE' AND off_al.alert_code = 'F1' LEFT JOIN datamart.prisons.nomis_reference_codes off_gen ON off_gen.code = offr.sex_code AND off_gen.domain = 'SEX' LEFT JOIN datamart.prisons.nomis_reference_codes off_eth ON offr.race_code = off_eth.code AND off_eth.domain = 'ETHNICITY' LEFT JOIN datamart.prisons.nomis_areas off_reg ON off_loc.noms_region_code = off_reg.area_code WHERE off_mr.military_seq IS NOT NULL OR off_al.alert_code IS NOT NULL",
      "parameters": [],
      "schema": {
        "field": [
          {
            "index": 0,
            "name": "PRISONER_NUMBER",
            "type": "string",
            "display": "Prisoner Number"
          },
          {
            "index": 1,
            "name": "DOB",
            "type": "string",
            "display": "Date of Birth"
          },
          {
            "index": 2,
            "name": "AGE",
            "type": "string",
            "display": "Age"
          },
