            "display": "Ethnicity"
          },
          {
            "index": 5,
            "name": "GROUPED_ETHNICITY",
            "type": "string",
            "display": "Grouped Ethnicity"
          },
          {
            "index": 6,
            "name": "PRISON",
            "type": "string",
            "display": "Establishment"
          },
          {
            "index": 7,
            "name": "REGION",
            "type": "string",
            "display": "Region (Male only)/Female Estate"
          },
          {
            "index": 8,
            "name": "HAS_MILITARY_RECORD",
            "type": "string",
            "display": "Has Military Record"
          },
          {
            "index": 9,
            "name": "HAS_VETERAN_FLAG",
            "type": "string",
            "display": "Has Veteran Alert Flag"
          },
          {
            "index": 10,
            "name": "SERVICE_NUMBER",
            "type": "string",
            "display": "Service Number"
          },
          {
            "index": 11,
            "name": "FIRST_NAME",
            "type": "string",
            "display": "First Name"
          }
          ,
          {
            "index": 12,
            "name": "LAST_NAME",
            "type": "string",
            "display": "Last Name"
          }
          ,
          {
            "index": 13,
            "name": "VALID_SERVICE_NUMBER",
            "type": "string",
            "display": "Valid Service Number"
          },
          {
            "index": 14,
            "name": "PRISON_CODE",
            "type": "string",
            "display": "Establishment Code"
          }
        ]
      }
    }
  ],
