            "display": "Total Incidents By Location",
            "column": {
              "key": [
                {
                  "id": "$ref:LOCATION",
                  "display": "Location"
                }
              ],
              "measure": [
                {
                  "id": "$ref:ESTABLISHMENT_NAME",
                  "display": "Name"
                },
                {
                  "id": "$ref:TOTAL",
                  "display": "Total Incidents"
                }
              ],
              "expectNull": true
            }
          },
          {
            "id": "incidents-by-location-type",
            "type": "list",
            "display": "Total Incidents By Location & Type",
            "column": {
              "key": [
                {
                  "id": "$ref:LOCATION",
                  "display": "Location"
                },                {
                  "id": "$ref:incident_type",
                  "display": "Incident Type"
                }
              ],
              "measure": [
                {
                  "id": "$ref:ESTABLISHMENT_NAME",
                  "display": "Name"
                },
                {
                  "id": "$ref:incident_type",
                  "display": "Incident Type"
                },
                {
                  "id": "$ref:TOTAL",
                  "display": "Total Incidents"
                }
              ],
              "expectNull": false
            }
          }
