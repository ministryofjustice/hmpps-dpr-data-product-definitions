
{
  "id": "inc002",
  "name": "MIS DARU Incident Tracker",
  "description": "The report is used by the Data Analysis and Reporting Unit (DARU) to monitor, assure and report against the volume and quality of Incidents data.<br/>INC0022 - v00.00.01  Last Modified: 24/05/18",
  "metadata": {
    "version": "1.1.0",
    "tags": [
      "INC0022  v00.00.01",
      "DPS", "Incident Reporting"
    ]
  },
  "datasource": [
    {
      "id": "athena",
      "name": "athena",
      "database": "prisons",
      "catalog": "AwsDataCatalog",
      "connection": "awsdatacatalog",
      "dialect": "postgres/19"
    }
  ],
  "dataset": [
    {
      "id": "inc0022-1",
      "name": "Incidents",
      "description": "MIS Incidents",
      "datasource": "athena",
      "query": "SELECT r.location, al.description location_name, ctf.description incident_type, COUNT(id) as TOTAL \nFROM prisons.incidentreporting_report r \njoin prisons.incidentreporting_constant_type ct ON r.type = ct.code \njoin prisons.incidentreporting_constant_type_family ctf ON ctf.code = ct.family_code \njoin prisons.nomis_agency_locations al on al.agy_loc_id = r.location\nWHERE date(r.reported_at) >= (SELECT START_DATE from prompt_) and date(r.reported_at) <= (SELECT END_DATE from prompt_) \nGROUP BY GROUPING SETS ( (r.location, al.description, ctf.description), (r.location, al.description), (ctf.description) ) ORDER BY al.description, ctf.description",
      "parameters": [
        {
          "index": 0,
          "name": "start_date",
          "filterType": "date",
          "reportFieldType": "date",
          "display": "Start reported incident date",
          "description": "",
          "mandatory": "true"
        },
        {
          "index": 1,
          "name": "end_date",
          "filterType": "date",
          "reportFieldType": "date",
          "display": "End reported incident date",
          "description": "",
          "mandatory": "true"
        }
      ],
      "schema": {
        "field": [
          {
            "index": 0,
            "name": "LOCATION",
            "type": "string",
            "display": "Prison ID"
          },
          {
            "index": 1,
            "name": "location_name",
            "type": "string",
            "display": "Prison Name"
          },
          {
            "index": 2,
            "name": "incident_type",
            "type": "string",
            "display": "Incident Type"
          },
          {
            "index": 3,
            "name": "TOTAL",
            "type": "int",
            "display": "Total"
          }
        ]
      }
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "INCIDENT_REPORTS__RO",
                "INCIDENT_REPORTS__RW",
                "INCIDENT_REPORTS__APPROVE"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "caseloads",
      "type": "row-level",
      "action": [
        "location IN (${caseloads}) OR location IS NULL"
      ],
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "exists": [
                "${caseloads}"
              ]
            }
          ]
        }
      ]
    }
  ],
  "report": [
    {
      "id": "116773.RS",
      "name": "Incident Tracker",
      "classification": "OFFICIAL",
      "version": "1.0.0",
      "render": "HTML",
      "dataset": "inc0022-1",
      "feature": [
        {
          "type": "print"
        }
      ],
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:location_name",
            "display": "Prison Name",
            "formula": "",
            "visible": "true",
            "sortable": true,
            "defaultsort": true,
            "legacyId": "DP2.DO20",
            "sortdirection": "asc"
          },
          {
            "name": "$ref:incident_type",
            "display": "Incident Type",
            "formula": "",
            "visible": "true",
            "sortable": true,
            "defaultsort": false,
            "legacyId": "DP2.DO20"
          },
          {
            "name": "$ref:TOTAL",
            "display": "Number of Incidents",
            "formula": "",
            "visible": "true",
            "sortable": false,
            "defaultsort": false,
            "legacyId": "DP2.DOc9"
          }
        ]
      }
    }
  ],
  "dashboard": [{
    "id": "incident-type-location",
    "name": "Incident Type/Location Breakdown",
    "description": "Incident Type/Location Breakdown",
    "dataset": "inc0022-1",
    "section": [
      {
        "id": "type-breakdown",
        "display": "Type breakdown",
        "visualisation": [
          {
            "id": "total-incidents",
            "type": "list",
            "display": "Total Incidents By Type",
            "column": {
              "key": [
                {
                  "id": "$ref:incident_type",
                  "display": "Incident Type"
                }
              ],
              "measure": [
                {
                  "id": "$ref:incident_type",
                  "display": "Incident Type"
                },
                {
                  "id": "$ref:TOTAL",
                  "display": "Total Incidents"
                }
              ],
              "expectNull": true
            }
          },
          {
            "id": "incidents-by-location",
            "type": "list",
            "display": "Total Incidents By Location",
            "column": {
              "key": [
                {
                  "id": "$ref:LOCATION",
                  "display": "Location"
                }
              ],
              "measure": [
                {
                  "id": "$ref:location_name",
                  "display": "Name"
                },
                {
                  "id": "$ref:TOTAL",
                  "display": "Total Incidents"
                }
              ],
              "expectNull": true
            }
          },
          {
            "id": "incidents-by-location-type",
            "type": "list",
            "display": "Total Incidents By Location & Type",
            "column": {
              "key": [
                {
                  "id": "$ref:LOCATION",
                  "display": "Location"
                },                {
                  "id": "$ref:incident_type",
                  "display": "Incident Type"
                }
              ],
              "measure": [
                {
                  "id": "$ref:location_name",
                  "display": "Name"
                },
                {
                  "id": "$ref:incident_type",
                  "display": "Incident Type"
                },
                {
                  "id": "$ref:TOTAL",
                  "display": "Total Incidents"
                }
              ],
              "expectNull": false
            }
          }
        ]
      }
    ]
  }]
}
