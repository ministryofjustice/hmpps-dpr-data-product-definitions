{
  "id": "residential-location-occupancy",
  "name": "Residential location occupancy",
  "description": "Residential location occupancy",
  "metadata": {
    "author": "Michael Willis",
    "version": "1.0.0",
    "owner": "Move a prisoner team"
  },
  "datasource": [
    {
      "id" : "datamart",
      "name" : "datamart"
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "MANAGE_RES_LOCATIONS_OP_CAP",
                "RESI__CERT_REVIEWER"
              ]
            }
          ]
        }
      ]
    }
  ],
  "dataset": [
    {
      "id": "cell-details",
      "name": "List of cell details",
      "datasource": "dps_locations",
      "query": "WITH used_for_agg AS (\n    SELECT \n        location_id,\n        CAST(LISTAGG(usage_type, ', ') WITHIN GROUP (ORDER BY usage_type) AS VARCHAR(4000)) as used_for_list\n    FROM (\n        SELECT DISTINCT location_id, INITCAP(REPLACE(used_for, '_', ' ')) as usage_type\n        FROM prisons.locationsinsideprison_cell_used_for\n    )\n    GROUP BY 1\n),\n\nspecialist_agg AS (\n    SELECT \n        location_id,\n        CAST(LISTAGG(spec_type, ', ') WITHIN GROUP (ORDER BY spec_type) AS VARCHAR(4000)) as specialist_list\n    FROM (\n        SELECT DISTINCT location_id, INITCAP(REPLACE(specialist_cell_type, '_', ' ')) as spec_type\n        FROM prisons.locationsinsideprison_specialist_cell\n    )\n    GROUP BY 1\n),\npopulation as (\n    SELECT ail2.agy_loc_id  AS prison_id,\n           ail2.description AS path_hierarchy,\n           count(*)         as no_of_occupant\n     FROM prisons.nomis_agency_internal_locations ail2\n     JOIN prisons.nomis_offender_bookings ob on ob.booking_seq = 1 AND ob.active_flag = 'Y' and ob.living_unit_id = ail2.internal_location_id\n     GROUP BY ail2.agy_loc_id, ail2.description\n)\nSELECT \n    l.id, \n    l.prison_id, \n    al.description AS prison_name,\n    l.path_hierarchy AS path_hierarchy, \n    INITCAP(l.local_name) AS local_name, \n    l.cell_mark,\n    (length(l.path_hierarchy) - length(replace(l.path_hierarchy, '-', ''))) + 1 AS level,\n    c.certified_normal_accommodation,\n    c.working_capacity,\n    c.max_capacity,\n    COALESCE(pop.no_of_occupant, 0) AS num_of_occupants,\n    -- Capacity logic\n    (CASE WHEN c.working_capacity = 0 THEN c.max_capacity ELSE c.working_capacity END) - COALESCE(pop.no_of_occupant, 0) AS spaces_available,\n    -- Crowding indicators\n    (CASE WHEN COALESCE(pop.no_of_occupant, 0) - COALESCE(c.certified_normal_accommodation, 0) > 0 THEN 'Y' ELSE 'N' END) AS crowded,\n    (CASE WHEN COALESCE(pop.no_of_occupant, 0) - COALESCE(c.certified_normal_accommodation, 0) > 0 \n          THEN COALESCE(pop.no_of_occupant, 0) - COALESCE(c.certified_normal_accommodation, 0) \n          ELSE NULL END) AS amount_over_capacity,\n    INITCAP(l.location_type) AS location_type,\n    INITCAP(l.status) AS status,\n    uf.used_for_list AS used_for,\n    sc.specialist_list AS specialist_types\nFROM \n    prisons.locationsinsideprison_location l \nJOIN \n    prisons.nomis_agency_locations al ON al.agy_loc_id = l.prison_id\nLEFT JOIN \n    population pop ON pop.path_hierarchy = l.prison_id || '-' || l.path_hierarchy AND pop.prison_id = l.prison_id\nLEFT JOIN \n    prisons.locationsinsideprison_capacity c ON l.capacity_id = c.id\nLEFT JOIN \n    used_for_agg uf ON l.id = uf.location_id\nLEFT JOIN \n    specialist_agg sc ON l.id = sc.location_id\nWHERE \n    l.location_type_discriminator = 'CELL' and l.converted_cell_type is null\n    AND l.status <> 'ARCHIVED'\n    AND al.active_flag = 'Y'",
      "schema": {
        "field": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string"
          },
          {
            "name": "path_hierarchy",
            "type": "string"
          },
          {
            "name": "local_name",
            "type": "string"
          },
          {
            "name": "cell_mark",
            "type": "string"
          },
          {
            "name": "level",
            "type": "int"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "certified_normal_accommodation",
            "type": "int"
          },
          {
            "name": "working_capacity",
            "type": "int"
          },
          {
            "name": "max_capacity",
            "type": "int"
          },
          {
            "name": "num_of_occupants",
            "type": "int"
          },
          {
            "name": "spaces_available",
            "type": "int"
          },
          {
            "name": "crowded",
            "type": "string"
          },
          {
            "name": "amount_over_capacity",
            "type": "int"
          },
          {
            "name": "location_type",
            "type": "string"
          },
          {
            "name": "used_for",
            "type": "string"
          },
          {
            "name": "specialist_types",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "prisons",
      "name": "Prisons",
      "datasource": "athena_redshift",
      "query": "select agy_loc_id prison_id, initcap(description) prison_name FROM prisons.nomis_agency_locations al \nwhere al.agency_location_type = 'INST'\nand al.active_flag = 'Y'\norder by description",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "display": "Prison Id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "display": "Prison name",
            "type": "string"
          }
        ]
      }
    }
  ],
  "report": [
    {
      "id": "cell-details",
      "name": "List of cell details",
      "description": "Details each cell and its capacity and attributes",
      "version": "1.0.0",
      "dataset": "$ref:cell-details",
      "render": "HTML",
      "feature": [
        {
          "type": "print"
        }
      ],
      "metadata": {
        "hints": [
          "interactive"
        ]
      },
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:prison_id",
            "display": "Prison ID",
            "sortable": false,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 140,
                "returnAsStaticOptions": true,
                "dataset": "prisons",
                "name": "prison_id",
                "display": "prison_name"
              }
            }
          },
          {
            "name": "$ref:prison_name",
            "display": "Prison Name",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:path_hierarchy",
            "display": "Cell Ref",
            "formula": "make_url('https://locations-inside-prison-${env}.hmpps.service.justice.gov.uk/view-and-update-locations/${prison_id}/${id}',${path_hierarchy},TRUE)",
            "sortable": true,
            "visible": "true",
            "defaultsort": true,
            "sortorder": "ascending"
          },
          {
            "name": "$ref:local_name",
            "display": "Local name",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:cell_mark",
            "display": "Door mark",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:level",
            "display": "Level",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:certified_normal_accommodation",
            "display": "CNA",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:working_capacity",
            "display": "Working capacity",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:max_capacity",
            "display": "Max capacity",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:num_of_occupants",
            "display": "Num occupants",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:spaces_available",
            "display": "Spaces",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:amount_over_capacity",
            "display": "Over capacity",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:crowded",
            "display": "Over-crowded",
            "sortable": true,
            "visible": "true",
            "defaultsort": false,
            "filter": {
              "type": "radio",
              "mandatory": false,
              "staticoptions": [
                {
                  "name": "Y",
                  "display": "Yes"
                },
                {
                  "name": "N",
                  "display": "No"
                }
              ]
            }
          },
          {
            "name": "$ref:location_type",
            "display": "Location type",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:used_for",
            "display": "Used for",
            "sortable": true,
            "visible": "false",
            "defaultsort": false,
            "wordwrap": "break-words"
          },
          {
            "name": "$ref:specialist_types",
            "display": "Specialist",
            "sortable": true,
            "visible": "false",
            "defaultsort": false,
            "wordwrap": "break-words"
          },
          {
            "name": "$ref:status",
            "display": "Status",
            "sortable": true,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": true,
              "default": "Active",
              "staticoptions": [
                {
                  "name": "Active",
                  "display": "Active"
                },
                {
                  "name": "Inactive",
                  "display": "Inactive"
                },
                {
                  "name": "Draft",
                  "display": "Draft"
                }
              ]
            }
          }
        ]
      },
      "destination": []
    }
  ]
}