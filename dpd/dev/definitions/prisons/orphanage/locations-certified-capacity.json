    },
    {
      "id": "accommodation-type-breakdown",
      "name": "Cells by accommodation type",
      "description": "Number of cells for each accommodation type.",
      "dataset": "accommodation-type-breakdown",
      "section": [
        {
          "id": "accommodation-type-breakdown-section",
          "display": "Cells by accommodation type",
          "visualisation": [
            {
              "id": "accommodation-type-breakdown-doughnut",
              "type": "doughnut",
              "display": "Cells by accommodation type",
              "column": {
                "key": [
                  {
                    "id": "$ref:accommodation_type",
                    "display": "Accommodation type"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:cell_count",
                    "display": "Number of cells",
                    "aggregate": "sum"
                  }
                ],
                "expectNull": false
              }
            },
            {
              "id": "accommodation-type-breakdown-list",
              "type": "list",
              "display": "Cells by accommodation type",
              "column": {
                "key": [
                  {
                    "id": "$ref:accommodation_type",
                    "display": "Accommodation type"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:cell_count",
                    "display": "Number of cells",
                    "aggregate": "sum"
                  }
                ],
                "expectNull": false
              }
            }
          ]
        }
      ]
    },
    {
      "id": "used-for-breakdown",
      "name": "Cells by used for",
      "description": "Number of cells for each 'used for' type. Cells with multiple used-for types are counted once per type.",
      "dataset": "used-for-breakdown",
      "section": [
        {
          "id": "used-for-breakdown-section",
          "display": "Cells by used for",
          "visualisation": [
            {
              "id": "used-for-breakdown-doughnut",
              "type": "doughnut",
              "display": "Cells by used for",
              "column": {
                "key": [
                  {
                    "id": "$ref:used_for",
                    "display": "Used for"
                  }
                ],
