    {
      "id": "certified-cell-list-download",
      "name": "Certified cells list (for download)",
      "description": "A flat list of every cell plus its wing/landing/spur parents (with rolled-up figures) for each prison with active certification, ordered by establishment then location. No sections or totals - intended for downloading to Excel, where the Type column can be used to filter to cells only. All figures are taken from the current live snapshot of locations.",
      "version": "1.0.0",
      "dataset": "$ref:certified-cells",
      "render": "HTML",
      "feature": [
        {
          "type": "print"
        }
      ],
      "metadata": {
        "hints": [
          "interactive"
        ]
      },
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:prison_id",
            "display": "Prison",
            "sortable": false,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 140,
                "returnAsStaticOptions": true,
                "dataset": "prisons",
                "name": "prison_id",
                "display": "prison_name"
              }
            }
          },
          {
            "name": "$ref:sort_key",
            "display": "Sort order",
            "sortable": true,
            "visible": "true",
            "defaultsort": true,
            "sortorder": "ascending"
          },
          {
            "name": "$ref:prison_name",
            "display": "Establishment",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
