{
  "id": "residential-certified-capacity",
  "name": "Certified cell capacity",
  "description": "Cells and capacity for every prison with active certification, taken from the current live snapshot of locations. Supports the Capacity Management team.",
  "metadata": {
    "author": "Michael Willis",
    "version": "1.0.0",
    "owner": "Capacity Management team",
    "tags": [
      "DPS",
      "Residential",
      "Capacity"
    ]
  },
  "datasource": [
    {
      "id": "datamart",
      "name": "datamart"
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "MANAGE_RES_LOCATIONS_OP_CAP",
                "RESI__CERT_VIEWER"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "caseloads",
      "type": "row-level",
      "action": [
        "prison_id IN (${caseloads})"
      ],
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "exists": [
                "${caseloads}"
              ]
            }
          ]
        }
      ]
    }
  ],
  "dataset": [
    {
      "id": "certified-cells",
      "name": "Certified cell list",
      "description": "One row per live cell for each prison with active certification, from the current snapshot of locations.",
      "datasource": "dps_locations",
      "query": "WITH used_for_agg AS (\n    SELECT location_id,\n           CAST(LISTAGG(usage_type, ', ') WITHIN GROUP (ORDER BY usage_type) AS VARCHAR(4000)) AS used_for_list\n    FROM (SELECT DISTINCT location_id, INITCAP(REPLACE(used_for, '_', ' ')) AS usage_type\n          FROM prisons.locationsinsideprison_cell_used_for)\n    GROUP BY 1\n),\nspecialist_agg AS (\n    SELECT location_id,\n           CAST(LISTAGG(spec_type, ', ') WITHIN GROUP (ORDER BY spec_type) AS VARCHAR(4000)) AS specialist_list\n    FROM (SELECT DISTINCT location_id, INITCAP(REPLACE(specialist_cell_type, '_', ' ')) AS spec_type\n          FROM prisons.locationsinsideprison_specialist_cell)\n    GROUP BY 1\n)\nSELECT\n    l.prison_id,\n    p.name AS prison_name,\n    l.id AS id,\n    l.code AS location_code,\n    l.path_hierarchy,\n    INITCAP(l.local_name) AS local_name,\n    l.cell_mark,\n    (length(l.path_hierarchy) - length(replace(l.path_hierarchy, '-', ''))) + 1 AS level,\n    INITCAP(l.status) AS status,\n    (CASE WHEN l.in_cell_sanitation THEN 'Yes' ELSE 'No' END) AS sanitation,\n    c.certified_normal_accommodation AS cna,\n    c.working_capacity,\n    c.max_capacity,\n    soc.signed_operation_capacity,\n    INITCAP(REPLACE(l.accommodation_type, '_', ' ')) AS accommodation_type,\n    sc.specialist_list AS cell_type,\n    uf.used_for_list AS used_for\nFROM prisons.locationsinsideprison_location l\nJOIN prisons.prisonregister_prison p ON p.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = l.prison_id\nLEFT JOIN prisons.locationsinsideprison_capacity c ON l.capacity_id = c.id\nLEFT JOIN prisons.locationsinsideprison_signed_operation_capacity soc ON soc.prison_id = l.prison_id\nLEFT JOIN used_for_agg uf ON l.id = uf.location_id\nLEFT JOIN specialist_agg sc ON l.id = sc.location_id\nWHERE l.location_type_discriminator = 'CELL'\n  AND l.converted_cell_type IS NULL\n  AND pc.certification_approval_required = true\n  AND p.active = true",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string"
          },
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "location_code",
            "type": "string"
          },
          {
            "name": "path_hierarchy",
            "type": "string"
          },
          {
            "name": "local_name",
            "type": "string"
          },
          {
            "name": "cell_mark",
            "type": "string"
          },
          {
            "name": "level",
            "type": "int"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "sanitation",
            "type": "string"
          },
          {
            "name": "cna",
            "type": "int"
          },
          {
            "name": "working_capacity",
            "type": "int"
          },
          {
            "name": "max_capacity",
            "type": "int"
          },
          {
            "name": "signed_operation_capacity",
            "type": "int"
          },
          {
            "name": "accommodation_type",
            "type": "string"
          },
          {
            "name": "cell_type",
            "type": "string"
          },
          {
            "name": "used_for",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "prisons",
      "name": "Prisons",
      "datasource": "athena_redshift",
      "query": "select prison_id, name prison_name FROM prisons.prisonregister_prison p where p.active = true order by name",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string",
            "display": "Prison Id"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Prison name"
          }
        ]
      }
    },
    {
      "id": "establishment-summary",
      "name": "Establishment totals",
      "datasource": "redshift",
      "query": "SELECT prison_name,\n       COUNT(*) AS cell_count,\n       SUM(cna) AS cna,\n       SUM(working_capacity) AS working_capacity,\n       SUM(max_capacity) AS max_capacity\nFROM ${tableId}\nGROUP BY prison_name",
      "schema": {
        "field": [
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          },
          {
            "name": "cna",
            "type": "int",
            "display": "CNA"
          },
          {
            "name": "working_capacity",
            "type": "int",
            "display": "Working capacity"
          },
          {
            "name": "max_capacity",
            "type": "int",
            "display": "Max capacity"
          }
        ]
      }
    },
    {
      "id": "grand-total-summary",
      "name": "Grand totals",
      "datasource": "redshift",
      "query": "SELECT COUNT(*) AS cell_count,\n       SUM(cna) AS cna,\n       SUM(working_capacity) AS working_capacity,\n       SUM(max_capacity) AS max_capacity\nFROM ${tableId}",
      "schema": {
        "field": [
          {
            "name": "cell_count",
            "type": "int",
            "display": "Total number of cells"
          },
          {
            "name": "cna",
            "type": "int",
            "display": "Total CNA"
          },
          {
            "name": "working_capacity",
            "type": "int",
            "display": "Total working capacity"
          },
          {
            "name": "max_capacity",
            "type": "int",
            "display": "Total max capacity"
          }
        ]
      }
    },
    {
      "id": "capacity-by-establishment",
      "name": "Capacity totals by establishment",
      "datasource": "dps_locations",
      "query": "SELECT\n    l.prison_id,\n    p.name AS prison_name,\n    COUNT(*) AS number_of_cells,\n    SUM(c.certified_normal_accommodation) AS cna,\n    SUM(c.working_capacity) AS working_capacity,\n    SUM(c.max_capacity) AS max_capacity,\n    MAX(soc.signed_operation_capacity) AS signed_operational_capacity,\n    SUM(CASE WHEN c.max_capacity = 1 AND l.status = 'ACTIVE' THEN 1 ELSE 0 END) AS active_single_cells,\n    SUM(CASE WHEN c.max_capacity = 1 AND l.status <> 'ACTIVE' THEN 1 ELSE 0 END) AS inactive_single_cells,\n    SUM(CASE WHEN c.max_capacity = 2 AND l.status = 'ACTIVE' THEN 1 ELSE 0 END) AS active_double_cells,\n    SUM(CASE WHEN c.max_capacity = 2 AND l.status <> 'ACTIVE' THEN 1 ELSE 0 END) AS inactive_double_cells,\n    SUM(CASE WHEN l.in_cell_sanitation THEN 1 ELSE 0 END) AS cells_with_sanitation,\n    SUM(CASE WHEN NOT l.in_cell_sanitation OR l.in_cell_sanitation IS NULL THEN 1 ELSE 0 END) AS cells_without_sanitation\nFROM prisons.locationsinsideprison_location l\nJOIN prisons.prisonregister_prison p ON p.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = l.prison_id\nLEFT JOIN prisons.locationsinsideprison_capacity c ON l.capacity_id = c.id\nLEFT JOIN prisons.locationsinsideprison_signed_operation_capacity soc ON soc.prison_id = l.prison_id\nWHERE l.location_type_discriminator = 'CELL'\n  AND l.converted_cell_type IS NULL\n  AND pc.certification_approval_required = true\n  AND p.active = true\nGROUP BY l.prison_id, p.name",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "number_of_cells",
            "type": "int",
            "display": "Number of cells"
          },
          {
            "name": "cna",
            "type": "int",
            "display": "CNA"
          },
          {
            "name": "working_capacity",
            "type": "int",
            "display": "Working capacity"
          },
          {
            "name": "max_capacity",
            "type": "int",
            "display": "Maximum capacity"
          },
          {
            "name": "signed_operational_capacity",
            "type": "int",
            "display": "Signed operational capacity"
          },
          {
            "name": "active_single_cells",
            "type": "int",
            "display": "Active single cells"
          },
          {
            "name": "inactive_single_cells",
            "type": "int",
            "display": "Inactive single cells"
          },
          {
            "name": "active_double_cells",
            "type": "int",
            "display": "Active double cells"
          },
          {
            "name": "inactive_double_cells",
            "type": "int",
            "display": "Inactive double cells"
          },
          {
            "name": "cells_with_sanitation",
            "type": "int",
            "display": "Cells with sanitation"
          },
          {
            "name": "cells_without_sanitation",
            "type": "int",
            "display": "Cells without sanitation"
          }
        ]
      }
    },
    {
      "id": "accommodation-type-breakdown",
      "name": "Cells by accommodation type",
      "datasource": "dps_locations",
      "query": "SELECT\n    l.prison_id,\n    p.name AS prison_name,\n    INITCAP(REPLACE(COALESCE(NULLIF(l.accommodation_type, ''), 'Unspecified'), '_', ' ')) AS accommodation_type,\n    COUNT(*) AS cell_count\nFROM prisons.locationsinsideprison_location l\nJOIN prisons.prisonregister_prison p ON p.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = l.prison_id\nWHERE l.location_type_discriminator = 'CELL'\n  AND l.converted_cell_type IS NULL\n  AND pc.certification_approval_required = true\n  AND p.active = true\nGROUP BY l.prison_id, p.name, 3",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "accommodation_type",
            "type": "string",
            "display": "Accommodation type"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          }
        ]
      }
    },
    {
      "id": "used-for-breakdown",
      "name": "Cells by used for",
      "datasource": "dps_locations",
      "query": "SELECT\n    l.prison_id,\n    p.name AS prison_name,\n    INITCAP(REPLACE(uf.used_for, '_', ' ')) AS used_for,\n    COUNT(*) AS cell_count\nFROM prisons.locationsinsideprison_location l\nJOIN prisons.prisonregister_prison p ON p.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_cell_used_for uf ON uf.location_id = l.id\nWHERE l.location_type_discriminator = 'CELL'\n  AND l.converted_cell_type IS NULL\n  AND pc.certification_approval_required = true\n  AND p.active = true\nGROUP BY l.prison_id, p.name, 3",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "used_for",
            "type": "string",
            "display": "Used for"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          }
        ]
      }
    },
    {
      "id": "cell-type-breakdown",
      "name": "Cells by cell type",
      "datasource": "dps_locations",
      "query": "SELECT\n    l.prison_id,\n    p.name AS prison_name,\n    INITCAP(REPLACE(sc.specialist_cell_type, '_', ' ')) AS cell_type,\n    COUNT(*) AS cell_count\nFROM prisons.locationsinsideprison_location l\nJOIN prisons.prisonregister_prison p ON p.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = l.prison_id\nJOIN prisons.locationsinsideprison_specialist_cell sc ON sc.location_id = l.id\nWHERE l.location_type_discriminator = 'CELL'\n  AND l.converted_cell_type IS NULL\n  AND pc.certification_approval_required = true\n  AND p.active = true\nGROUP BY l.prison_id, p.name, 3",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "cell_type",
            "type": "string",
            "display": "Cell type"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          }
        ]
      }
    }
  ],
  "report": [
    {
      "id": "certified-cell-list",
      "name": "Certified cells by establishment",
      "description": "Lists every cell for each prison with active certification, grouped by establishment, with per-establishment and overall totals. All figures are taken from the current live snapshot of locations.",
      "version": "1.0.0",
      "dataset": "$ref:certified-cells",
      "render": "HTML",
      "summary": [
        {
          "id": "establishment-summary",
          "template": "section-footer",
          "dataset": "$ref:establishment-summary"
        },
        {
          "id": "grand-total-summary",
          "template": "page-footer",
          "dataset": "$ref:grand-total-summary"
        }
      ],
      "feature": [
        {
          "type": "print"
        }
      ],
      "metadata": {
        "hints": [
          "interactive"
        ]
      },
      "specification": {
        "template": "list-section",
        "section": [
          "prison_name"
        ],
        "field": [
          {
            "name": "$ref:prison_id",
            "display": "Prison",
            "sortable": false,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 140,
                "returnAsStaticOptions": true,
                "dataset": "prisons",
                "name": "prison_id",
                "display": "prison_name"
              }
            }
          },
          {
            "name": "$ref:prison_name",
            "display": "Establishment",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:location_code",
            "display": "Location code (Cell)",
            "sortable": true,
            "visible": "mandatory",
            "defaultsort": false
          },
          {
            "name": "$ref:path_hierarchy",
            "display": "Cell Ref",
            "formula": "make_url('https://locations-inside-prison-${env}.hmpps.service.justice.gov.uk/view-and-update-locations/${prison_id}/${id}',${path_hierarchy},TRUE)",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:local_name",
            "display": "Local name",
            "sortable": true,
            "visible": "true",
            "defaultsort": true,
            "sortorder": "ascending"
          },
          {
            "name": "$ref:cell_mark",
            "display": "Door mark",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:cna",
            "display": "CNA",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:working_capacity",
            "display": "Certified working capacity",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:max_capacity",
            "display": "Max capacity",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:signed_operation_capacity",
            "display": "Signed operational capacity",
            "sortable": true,
            "visible": "false",
            "defaultsort": false
          },
          {
            "name": "$ref:status",
            "display": "Status",
            "sortable": true,
            "visible": "true",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": true,
              "default": "Active",
              "staticoptions": [
                {
                  "name": "Active",
                  "display": "Active"
                },
                {
                  "name": "Inactive",
                  "display": "Inactive"
                },
                {
                  "name": "Archived",
                  "display": "Archived"
                },
                {
                  "name": "Draft",
                  "display": "Draft"
                }
              ]
            }
          },
          {
            "name": "$ref:sanitation",
            "display": "Sanitation",
            "sortable": true,
            "visible": "true",
            "defaultsort": false,
            "filter": {
              "type": "radio",
              "mandatory": false,
              "staticoptions": [
                {
                  "name": "Yes",
                  "display": "Yes"
                },
                {
                  "name": "No",
                  "display": "No"
                }
              ]
            }
          },
          {
            "name": "$ref:accommodation_type",
            "display": "Accommodation type",
            "sortable": true,
            "visible": "true",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "staticoptions": [
                {
                  "name": "Care And Separation",
                  "display": "Care And Separation"
                },
                {
                  "name": "Healthcare Inpatients",
                  "display": "Healthcare Inpatients"
                },
                {
                  "name": "Normal Accommodation",
                  "display": "Normal Accommodation"
                },
                {
                  "name": "Other Non Residential",
                  "display": "Other Non Residential"
                }
              ]
            },
            "wordwrap": "break-words"
          },
          {
            "name": "$ref:cell_type",
            "display": "Cell type",
            "sortable": true,
            "visible": "true",
            "defaultsort": false,
            "wordwrap": "break-words"
          },
          {
            "name": "$ref:used_for",
            "display": "Used for",
            "sortable": true,
            "visible": "true",
            "defaultsort": false,
            "wordwrap": "break-words"
          }
        ]
      },
      "destination": []
    }
  ],
  "dashboard": [
    {
      "id": "certified-capacity-summary",
      "name": "Certified capacity summary by establishment",
      "description": "Capacity totals from the current live snapshot of locations for each establishment with active certification.",
      "dataset": "capacity-by-establishment",
      "section": [
        {
          "id": "capacity-totals",
          "display": "Certified capacity totals by establishment",
          "visualisation": [
            {
              "id": "capacity-totals-list",
              "type": "list",
              "display": "Certified capacity totals",
              "column": {
                "key": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Establishment"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:number_of_cells",
                    "display": "Number of cells",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:cna",
                    "display": "CNA",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:working_capacity",
                    "display": "Working capacity",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:cna",
                    "display": "Certified working capacity",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:max_capacity",
                    "display": "Maximum capacity",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:signed_operational_capacity",
                    "display": "Signed operational capacity",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:active_single_cells",
                    "display": "Active single cells",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:inactive_single_cells",
                    "display": "Inactive single cells",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:active_double_cells",
                    "display": "Active double cells",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:inactive_double_cells",
                    "display": "Inactive double cells",
                    "aggregate": "sum"
                  },
                  {
                    "id": "$ref:cells_with_sanitation",
                    "display": "Cells with sanitation",
                    "aggregate": "sum"
                  },
                  {
