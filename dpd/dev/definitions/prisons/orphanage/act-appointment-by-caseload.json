  "datasource": [
    {
      "id": "datamart",
      "name": "datamart"
    },
    {
      "id": "athena",
      "name": "athena",
      "database": "curated",
      "catalog": "awsdatacatalog",
      "connection": "awsdatacatalog",
      "dialect": "athena/3"
    }
