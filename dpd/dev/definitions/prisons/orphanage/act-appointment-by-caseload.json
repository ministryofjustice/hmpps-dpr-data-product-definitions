  "dataset": [
    {
      "id": "appointment-attendance",
      "name": "Appointment attendance by date",
      "datasource": "athena",
      "query": "WITH ofrel AS ( SELECT row_number() over ( partition by curated.nomis_offender_profile_details.offender_book_id ) as rn, curated.nomis_offender_profile_details.offender_book_id, curated.nomis_offender_profile_details.profile_code, curated.nomis_profile_codes.description FROM curated.nomis_offender_profile_details LEFT JOIN curated.nomis_profile_codes ON curated.nomis_profile_codes.profile_code = curated.nomis_offender_profile_details.profile_code where curated.nomis_offender_profile_details.profile_type = 'RELF' ), ethnicity_domain AS ( SELECT code, domain, description from curated.nomis_reference_codes where domain = 'ETHNICITY' ), nationality_info AS ( select row_number() over (partition by offender_book_id) as rn, offender_book_id, curated.nomis_profile_codes.profile_code as code, curated.nomis_profile_codes.description from curated.nomis_offender_profile_details left join curated.nomis_profile_codes on curated.nomis_offender_profile_details.profile_code = curated.nomis_profile_codes.profile_code where curated.nomis_offender_profile_details.profile_type = 'NAT' ), gender_domain AS ( SELECT code, domain, description from curated.nomis_reference_codes where domain = 'SEX' ), person_prisoner AS ( SELECT o.offender_id_display as prisoner_number, o.first_name, o.last_name, REGEXP_REPLACE( LOWER(o.last_name || ', ' || o.first_name), '(\\b[a-z])', x -> UPPER(x[1]) ) AS name, o.birth_date as date_of_birth, DATE_DIFF('hour', o.birth_date, CURRENT_DATE) / 8766 AS age, ob.offender_book_id as latest_booking_id, ob.booking_no as latest_book_number, ob.agy_loc_id as prison_id, I.description as cell_location, I.internal_location_id as location_uuid, o.sex_code AS gender_code, gender_domain.description AS gender, CASE WHEN o.race_code = 'W8' then 'W3' WHEN o.race_code = 'O1' then 'A4' ELSE o.race_code END AS ethnicity_code, ethnicity_domain.description AS ethnicity, nationality_info.code AS nationality_code, nationality_info.description AS nationality, ofrel.profile_code AS religion_code, ofrel.description AS religion, ob.in_out_status, ob.active_flag AS active FROM curated.nomis_offender_bookings ob INNER JOIN curated.\"nomis_offenders\" o ON ob.offender_id = o.offender_id AND ob.booking_seq = 1 LEFT JOIN curated.nomis_agency_internal_locations I ON ob.living_unit_id = i.internal_location_id LEFT JOIN gender_domain ON o.sex_code = gender_domain.code LEFT JOIN ethnicity_domain ON o.race_code = ethnicity_domain.code LEFT JOIN nationality_info ON ob.offender_book_id = nationality_info.offender_book_id AND nationality_info.rn = 1 LEFT JOIN ofrel ON ofrel.offender_book_id = ob.offender_book_id AND ofrel.rn = 1 ) SELECT prison_code, par.name                                                          AS parent_name, cat.description                                                   AS category_description, category_code, custom_name, COALESCE(custom_name, '') || ' ( ' || cat.description || ' )'          AS appointment_name, appointment_id, appointment_tier_id                                               AS appointment_tier, start_date, substring(start_time, 0, 6) || ' - ' || substring(end_time, 0, 6) AS start_to_end, prisoner_number, dm.name, substring(dm.cell_location, 5, 10)                                AS cell_location, CASE WHEN app.cancellation_reason_id IS NOT NULL THEN 'Cancelled' WHEN attended IS NULL THEN 'Not recorded' WHEN attended = false THEN 'Did not attend' WHEN attended THEN 'Attended' END                             AS attended FROM curated.activities_appointment_attendee att LEFT JOIN curated.activities_appointment app USING (appointment_id) LEFT JOIN curated.activities_appointment_category cat ON cat.code = category_code LEFT JOIN curated.activities_appointment_parent_category par USING (appointment_parent_category_id) LEFT JOIN person_prisoner dm USING (prisoner_number) WHERE appointment_tier_id in (1, 2) AND (dm.prison_id NOT IN ('ZZGHI')) AND NOT app.is_deleted AND NOT att.is_deleted ORDER by start_date, start_time",
      "schema": {
        "field": [
          {
            "name": "prison_code",
            "type": "string",
            "display": "Prison"
          },
          {
            "name": "parent_name",
            "type": "string",
            "display": ""
          },
          {
            "name": "category_description",
            "type": "string",
            "display": ""
          },
          {
            "name": "category_code",
            "type": "string",
            "display": "Cell location"
          },
          {
            "name": "custom_name",
            "type": "string",
            "display": ""
          },
          {
            "name": "appointment_name",
            "type": "string",
            "display": "Name"
          },
          {
            "name": "appointment_id",
            "type": "string",
            "display": ""
          },
          {
            "name": "appointment_tier",
            "type": "string",
            "display": "Tier"
          },
          {
            "name": "start_date",
            "type": "string",
            "display": "Date"
          },
          {
            "name": "start_to_end",
            "type": "string",
            "display": ""
          },
          {
            "name": "prisoner_number",
            "type": "string",
            "display": "NOMIS Number"
          },
          {
            "name": "name",
            "type": "string",
            "display": "Name"
          },
          {
            "name": "cell_location",
            "type": "string",
            "display": "Cell location"
          },
          {
            "name": "attended",
            "type": "string",
            "display": "Attended"
          }
        ]
      }
    },
    {
      "id": "appointment-summary",
      "name": "Appointment attendance summary for visualisation",
      "datasource": "datamart",
      "query": "SELECT start_date AS ts, prison_code, CASE WHEN att.is_deleted THEN 'Cancelled' WHEN attended IS NULL THEN 'Not recorded' WHEN attended = false THEN 'Did not attend' WHEN attended THEN 'Attended' WHEN appointment_tier_id = 1 THEN 'Tier 1' WHEN appointment_tier_id = 2 THEN 'Tier 2' WHEN appointment_tier_id = 3 THEN 'Routine' END AS type, count(*) FROM datamart.prisons.activities_appointment_attendee att LEFT JOIN datamart.prisons.activities_appointment app USING (appointment_id) LEFT JOIN datamart.person.prisoner dm USING (prisoner_number) WHERE appointment_tier_id in (1, 2) AND (dm.prison_id IN ('LEI')) GROUP BY ts, prison_code,type ORDER by ts",
      "schema": {
        "field": [
          {
            "name": "ts",
            "type": "string",
            "display": "Date"
          },
          {
            "name": "prison_code",
            "type": "string",
            "display": "Code"
          },
          {
            "name": "type",
            "type": "string",
            "display": "Code"
          },
          {
            "name": "count",
            "type": "int",
            "display": "Count"
          }
        ]
      }
    },
    {
      "id": "appointment-summary-by-date",
      "name": "Appointment attendance summary by date range",
      "datasource": "datamart",
      "query": "SELECT a.start_date AS ts, a.prison_code, count(distinct a.appointment_id) AS appointment_count, count(aa.appointment_attendee_id) AS attendee_count, sum( CASE WHEN aa.attended IS TRUE THEN 1 ELSE 0 END ) AS attended_count, sum( CASE WHEN aa.attended IS FALSE THEN 1 ELSE 0 END ) AS non_attended_count, sum( CASE WHEN aa.attended IS NULL AND a.cancellation_reason_id IS NULL THEN 1 ELSE 0 END ) AS not_recorded_count, sum( CASE WHEN a.cancellation_reason_id THEN 1 ELSE 0 END ) AS cancelled_count, sum( CASE WHEN a.is_deleted THEN 1 ELSE 0 END ) AS deleted_count, CASE WHEN appointment_count THEN appointment_count - cancelled_count ELSE 0 END AS appointments, CASE WHEN attendee_count THEN attendee_count - cancelled_count ELSE 0 END AS attendees, CASE WHEN cancelled_count THEN cancelled_count - deleted_count ELSE 0 END AS cancellations, CASE WHEN attendees THEN round(attended_count / attendees::FLOAT * 100, 0) ELSE 0 END AS attended_pct, CASE WHEN attendees THEN round(non_attended_count / attendees::FLOAT * 100, 0) ELSE 0 END AS non_attended_pct, CASE WHEN attendees THEN round(not_recorded_count / attendees::FLOAT * 100, 0) ELSE 0 END AS not_recorded_pct, count( CASE WHEN appointment_tier_id = 1 AND attended THEN appointment_tier_id END ) AS tier1, count( CASE WHEN appointment_tier_id = 2 AND attended THEN appointment_tier_id END ) AS tier2, CASE WHEN attendees THEN round(tier1 / attendees::FLOAT * 100, 0) ELSE 0 END AS tier1_pct, CASE WHEN attendees THEN round(tier2 / attendees::FLOAT * 100, 0) ELSE 0 END AS tier2_pct FROM datamart.prisons.activities_appointment_attendee aa LEFT JOIN datamart.prisons.activities_appointment a ON a.appointment_id = aa.appointment_id WHERE aa.removal_reason_id IS NULL AND ts IS NOT NULL AND NOT a.is_deleted AND NOT aa.is_deleted AND appointment_tier_id in (1, 2) GROUP BY GROUPING SETS ((ts, a.prison_code), ()) ORDER by ts, a.prison_code",
      "schema": {
        "field": [
          {
            "name": "ts",
            "type": "timestamp",
            "display": "Date",
            "formula": "format_date(${ts}, 'dd MMMM yyyy')",
            "filter": {
              "index": 0,
              "type": "daterange",
              "interactive": "true",
              "default": "today(-1, months) - today()"
            }
          },
          {
            "name": "prison_code",
            "type": "string",
            "display": "Code"
          },
          {
            "name": "appointment_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "attendee_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "attended_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "non_attended_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "not_recorded_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "cancelled_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "deleted_count",
            "type": "int",
            "display": ""
          },
          {
            "name": "appointments",
            "type": "int",
            "display": ""
          },
          {
            "name": "attendees",
            "type": "int",
            "display": ""
          },
          {
            "name": "cancellations",
            "type": "int",
            "display": ""
          },
          {
            "name": "attended_pct",
            "type": "int",
            "display": ""
          },
          {
            "name": "non_attended_pct",
            "type": "int",
            "display": ""
          },
          {
            "name": "not_recorded_pct",
            "type": "int",
            "display": ""
          },
          {
            "name": "tier1",
            "type": "int",
            "display": "Tier 1"
          },
          {
            "name": "tier2",
            "type": "int",
            "display": "Tier 2"
          },
          {
            "name": "tier1_pct",
            "type": "int",
            "display": "Tier 1"
          },
          {
            "name": "tier2_pct",
            "type": "int",
            "display": "t2p"
          }
        ]
      }
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "ROLE_ACTIVITY_HUB",
                "ROLE_PRISONS_REPORTING_USER"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "caseload",
      "type": "row-level",
      "action": [
        "prison_code = '${caseload}' OR prison_code = 'OUT'"
      ],
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "exists": [
                "${caseload}"
              ]
            }
          ]
        }
      ]
    }
  ],
