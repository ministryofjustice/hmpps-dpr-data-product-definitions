{
  "id": "incidenter-type-tracker",
  "name": "Incident Type Tracker",
  "description": "The report is used by the Data Analysis and Reporting Unit (DARU) to monitor, assure and report against the volume and quality of Incidents data.<br/>INC0022 - v00.00.01  Last Modified: 24/05/18",
  "metadata": {
    "version": "1.1.0",
    "tags": [
      "INC0022  v00.00.01",
      "DPS",
      "Incident Reporting"
    ]
  },
  "datasource": [
    {
      "id" : "datamart",
      "name" : "datamart"
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "INCIDENT_REPORTS__RO",
                "INCIDENT_REPORTS__RW",
                "INCIDENT_REPORTS__APPROVE"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "caseloads",
      "type": "row-level",
      "action": [
        "location IN (${caseloads})"
      ],
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "exists": [
                "${caseloads}"
              ]
            }
          ]
        }
      ]
    }
  ],
  "dataset": [
    {
      "id": "types",
      "name": "Incident Types",
      "datasource": "datamart",
      "query": "SELECT code, description FROM prisons.incidentreporting_constant_type_family",
      "schema": {
        "field": [
          {
            "name": "code",
            "display": "Type code",
            "type": "string"
          },
          {
            "name": "description",
            "display": "Type description",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "prisons",
      "name": "Prisons",
      "datasource": "datamart",
      "query": "select agy_loc_id prison_id, description prison_name FROM prisons.nomis_agency_locations al \nwhere al.agency_location_type = 'INST'\nand al.active_flag = 'Y' AND al.agy_loc_id NOT IN ('TRN', 'OUT')\norder by description",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "display": "Prison Id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "display": "Prison name",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "type-summary",
      "name": "Incident Types",
      "datasource": "datamart",
      "query": "SELECT r.location, al.description prison_name, ctf.code incident_type_code, ctf.description incident_type_description, COUNT(id) as total\nFROM prisons.incidentreporting_report r\njoin prisons.incidentreporting_constant_type ct on r.type = ct.code\n       join prisons.incidentreporting_constant_type_family ctf on ctf.code = ct.family_code\n       join prisons.nomis_agency_locations al on al.agy_loc_id = r.location\nWHERE status NOT IN ('DUPLICATE', 'NOT_REPORTABLE')\nGROUP BY GROUPING SETS ( (r.location, al.description, ctf.code, ctf.description), (ctf.code, ctf.description), (r.location, al.description) ) order by incident_type_code, r.location",
      "schema": {
        "field": [
          {
            "index": 0,
            "name": "location",
            "type": "string",
            "display": "Prison ID"
          },
          {
            "index": 1,
            "name": "prison_name",
            "type": "string",
            "display": "Prison name"
          },
          {
            "index": 2,
            "name": "incident_type_code",
            "type": "string",
            "display": "Type Code"
          },
          {
            "index": 3,
            "name": "incident_type_description",
            "type": "string",
            "display": "Type description"
          },
          {
            "index": 4,
            "name": "total",
            "type": "string",
            "display": "Total"
          }
        ]
      }
    }
  ],
  "report": [
    {
      "id": "116773.RS",
      "name": "Incident Type Tracker",
      "classification": "OFFICIAL",
      "version": "1.0.0",
      "render": "HTML",
      "dataset": "type-summary",
      "feature": [
        {
          "type": "print"
        }
      ],
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:location",
            "display": "Location",
            "sortable": true,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 140,
                "returnAsStaticOptions": true,
                "dataset": "prisons",
                "name": "prison_id",
                "display": "prison_name"
              }
            }
          },
          {
            "name": "$ref:prison_name",
            "display": "Prison Name",
            "visible": "true",
            "sortable": true,
            "defaultsort": true,
            "sortdirection": "asc"
          },
          {
            "name": "$ref:incident_type_code",
            "display": "Type code",
            "sortable": false,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 60,
                "returnAsStaticOptions": true,
                "dataset": "types",
                "name": "code",
                "display": "description"
              }
            }
          },
          {
            "name": "$ref:incident_type_description",
            "display": "Incident Type",
            "visible": "true",
            "sortable": true,
            "defaultsort": false
          },
          {
            "name": "$ref:total",
            "display": "Number of Incidents",
            "formula": "",
            "visible": "true",
            "sortable": false,
            "defaultsort": false
          }
        ]
      }
    }
  ],
  "dashboard": [
    {
      "id": "incident-type-location",
      "name": "Incident Type/Location Breakdown",
      "description": "Incident Type/Location Breakdown",
      "dataset": "type-summary",
      "section": [
        {
          "id": "type-breakdown",
          "display": "Type breakdown",
          "visualisation": [
            {
              "id": "incidents-by-location",
              "type": "list",
              "display": "Total Incidents By Prison",
              "column": {
                "key": [
                  {
                    "id": "$ref:location",
                    "display": "Prison ID"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Prison Name"
                  },
                  {
                    "id": "$ref:total",
                    "display": "Total Incidents"
                  }
                ],
                "expectNull": true
              }
            },
            {
              "id": "incidents-by-location-type",
              "type": "list",
              "display": "Total Incidents By Location & Type",
              "column": {
                "key": [
                  {
                    "id": "$ref:location",
                    "display": "Prison ID"
                  },
                  {
                    "id": "$ref:incident_type_code",
                    "display": "Incident Type"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Prison Name"
                  },
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Incident Type"
                  },
                  {
                    "id": "$ref:total",
                    "display": "Total Incidents"
                  }
                ],
                "expectNull": false
              }
            },
            {
              "id": "incidents-by-type",
              "type": "list",
              "display": "Total Incidents By Type",
              "column": {
                "key": [
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Type Name"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Incident Type"
                  },
                  {
                    "id": "$ref:total",
                    "display": "Total Incidents"
                  }
                ],
                "expectNull": true
              }
            }
          ]
        }
      ]
    }
  ]
}
