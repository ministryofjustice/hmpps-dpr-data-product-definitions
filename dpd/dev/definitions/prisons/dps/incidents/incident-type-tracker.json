{
  "id": "incidenter-type-tracker",
  "name": "Incident Type Tracker",
  "description": "The report is used by the Data Analysis and Reporting Unit (DARU) to monitor, assure and report against the volume and quality of Incidents data.<br/>INC0022 - v00.00.01  Last Modified: 24/05/18",
  "metadata": {
    "version": "1.1.0",
    "tags": [
      "INC0022  v00.00.01",
      "DPS",
      "Incident Reporting"
    ]
  },
  "datasource": [
    {
      "id": "athena_redshift",
      "name": "athena_redshift_federated",
      "database": "datamart",
      "catalog": "redshift_datamart",
      "connection": "federated",
      "dialect": "redshift/4"
    }
  ],
  "dataset": [
    {
      "id": "type-summary",
      "name": "Incident Types",
      "datasource": "athena_redshift",
      "query": "SELECT r.location prison_id, al.description prison_name, ctf.code incident_type_code, ctf.description incident_type_description, COUNT(id) as total\nFROM prisons.incidentreporting_report r\njoin prisons.incidentreporting_constant_type ct on r.type = ct.code\n       join prisons.incidentreporting_constant_type_family ctf on ctf.code = ct.family_code\n       join nomis_agency_locations al on al.agy_loc_id = r.location\nWHERE status NOT IN ('DUPLICATE', 'NOT_REPORTABLE')\nand date(incident_date_and_time) >= (SELECT START_DATE from prompt_) and date(incident_date_and_time) <= (SELECT END_DATE from prompt_)\nGROUP BY GROUPING SETS ( (r.location, al.description, ctf.code, ctf.description), (r.location, al.description), (ctf.code, ctf.description) ) \nORDER BY al.description, ctf.description",
      "parameters": [
        {
          "index": 0,
          "name": "start_date",
          "filterType": "date",
          "reportFieldType": "date",
          "display": "Enter Incident Date (Start)",
          "description": "",
          "mandatory": "true"
        },
        {
          "index": 1,
          "name": "end_date",
          "filterType": "date",
          "reportFieldType": "date",
          "display": "Enter Incident Date (End)",
          "description": "",
          "mandatory": "true"
        }
      ],
      "schema": {
        "field": [
          {
            "index": 0,
            "name": "prison_id",
            "type": "string",
            "display": "Prison ID"
          },
          {
            "index": 1,
            "name": "prison_name",
            "type": "string",
            "display": "Prison name"
          },
          {
            "index": 2,
            "name": "incident_type_code",
            "type": "string",
            "display": "Type Code"
          },
          {
            "index": 3,
            "name": "incident_type_description",
            "type": "string",
            "display": "Type description"
          },
          {
            "index": 4,
            "name": "total",
            "type": "string",
            "display": "Total"
          }
        ]
      }
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "ROLE_PRISONS_REPORTING_USER"
              ]
            }
          ]
        }
      ]
    }
  ],
  "report": [
    {
      "id": "116773.RS",
      "name": "Incident Type Tracker",
      "classification": "OFFICIAL",
      "version": "1.0.0",
      "render": "HTML",
      "dataset": "type-summary",
      "feature": [
        {
          "type": "print"
        }
      ],
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:prison_name",
            "display": "Prison Name",
            "formula": "",
            "visible": "true",
            "sortable": true,
            "defaultsort": true,
            "legacyId": "DP2.DO20"
          },
          {
            "name": "$ref:incident_type_description",
            "display": "Incident Type",
            "formula": "",
            "visible": "true",
            "sortable": true,
            "defaultsort": false,
            "legacyId": "DP2.DO20"
          },
          {
            "name": "$ref:total",
            "display": "Number of Incidents",
            "formula": "",
            "visible": "true",
            "sortable": false,
            "defaultsort": false,
            "legacyId": "DP2.DOc9"
          }
        ]
      }
    }
  ],
  "dashboard": [
    {
      "id": "incident-type-location",
      "name": "Incident Type/Location Breakdown",
      "description": "Incident Type/Location Breakdown",
      "dataset": "type-summary",
      "section": [
        {
          "id": "type-breakdown",
          "display": "Type breakdown",
          "visualisation": [
            {
              "id": "total-incidents",
              "type": "list",
              "display": "Total Incidents By Type",
              "column": {
                "key": [
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Incident Type"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Incident Type"
                  },
                  {
                    "id": "$ref:total",
                    "display": "Total Incidents"
                  }
                ],
                "expectNull": true
              }
            },
            {
              "id": "incidents-by-location",
              "type": "list",
              "display": "Total Incidents By Prison",
              "column": {
                "key": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Prison Name"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Prison Name"
                  },
                  {
                    "id": "$ref:total",
                    "display": "Total Incidents"
                  }
                ],
                "expectNull": true
              }
            },
            {
              "id": "incidents-by-location-type",
              "type": "list",
              "display": "Total Incidents By Location & Type",
              "column": {
                "key": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Prison Name"
                  },
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Incident Type"
                  }
                ],
                "measure": [
                  {
                    "id": "$ref:prison_name",
                    "display": "Prison Name"
                  },
                  {
                    "id": "$ref:incident_type_description",
                    "display": "Incident Type"
                  },
                  {
                    "id": "$ref:total",
                    "display": "Total Incidents"
                  }
                ],
                "expectNull": false
              }
            }
          ]
        },
        {
          "id": "debug",
          "display": "Debug",
          "visualisation": [
            {
              "id": "all-data",
              "type": "list",
              "display": "All data",
              "column": {
                "measure": [],
                "expectNull": true
              }
            }
          ]
        }
      ]
    }
  ]
}
