
{
  "id": "inc002",
  "name": "Incident Tracker Reports",
  "description": "The report is used by the Data Analysis and Reporting Unit (DARU) to monitor, assure and report against the volume and quality of Incidents data.<br/>INC0022 - v00.00.01  Last Modified: 15/04/26",
  "metadata": {
    "version": "1.2.0",
    "tags": [
      "INC0022  v00.00.01",
      "DPS", "Incident Reporting"
    ]
  },
  "datasource": [
    {
      "id": "athena",
      "name": "athena",
      "database": "prisons",
      "catalog": "AwsDataCatalog",
      "connection": "awsdatacatalog",
      "dialect": "postgres/19"
    },
    {
      "id": "datamart",
      "name": "datamart"
    }
  ],
  "dataset": [
    {
      "id": "inc0022-1",
      "name": "Incidents",
      "description": "MIS Incidents",
      "datasource": "athena",
      "query": "SELECT \n    format_datetime((SELECT START_DATE from prompt_), 'dd/MM/yyyy') start_date,\n    format_datetime((SELECT END_DATE from prompt_), 'dd/MM/yyyy') end_date,\n    r.location, \n    p.name AS location_name, \n    ctf.code AS incident_code, \n    ctf.description AS incident_type, \n    cs.code AS status_code, \n    cs.description AS status, COUNT(r.id) AS TOTAL \nFROM prisons.incidentreporting_report r \nJOIN prisons.incidentreporting_constant_type ct \n    ON r.type = ct.code \nJOIN prisons.incidentreporting_constant_type_family ctf \n    ON ctf.code = ct.family_code \nJOIN prisons.incidentreporting_constant_status cs \n    ON cs.code = r.status \nJOIN prisons.prisonregister_prison p \n    ON p.prison_id = r.location\nWHERE cs.code NOT IN ('DUPLICATE', 'NOT_REPORTABLE')\nand date(r.incident_date_and_time) >= (SELECT START_DATE from prompt_) and date(r.incident_date_and_time) <= (SELECT END_DATE from prompt_) \nGROUP BY GROUPING SETS (\n    (r.location, p.name, ctf.code, ctf.description, cs.code, cs.description), \n    (r.location, p.name, ctf.code, ctf.description), \n    (r.location, p.name, cs.code, cs.description), \n    (r.location, p.name),\n    (ctf.code, ctf.description), \n    (cs.code, cs.description) \n)\nORDER BY p.name, ctf.description, cs.description",
      "parameters": [
        {
          "index": 0,
          "name": "start_date",
          "filterType": "date",
          "reportFieldType": "date",
          "display": "Start incident date",
          "mandatory": "true"
        },
        {
          "index": 1,
          "name": "end_date",
          "filterType": "date",
          "reportFieldType": "date",
          "display": "End incident date",
          "mandatory": "true"
        }
      ],
      "schema": {
        "field": [
          {
            "index": 0,
            "name": "start_date",
            "type": "date",
            "display": "Start incident date"
          },
          {
            "index": 1,
            "name": "end_date",
            "type": "date",
            "display": "End incident date"
          },
          {
            "index": 2,
            "name": "location",
            "type": "string",
            "display": "Prison ID"
          },
          {
            "index": 3,
            "name": "location_name",
            "type": "string",
            "display": "Prison Name"
          },
          {
            "index": 4,
            "name": "incident_code",
            "type": "string",
            "display": "Incident Code"
          },
          {
            "index": 5,
            "name": "incident_type",
            "type": "string",
            "display": "Incident Type"
          },
          {
            "index": 6,
            "name": "status_code",
            "type": "string",
            "display": "Status Code"
          },
          {
            "index": 7,
            "name": "status",
            "type": "string",
            "display": "Status"
          },
          {
            "index": 8,
            "name": "TOTAL",
            "type": "int",
            "display": "Total"
          }
        ]
      }
    },
    {
      "id": "incident-history",
      "name": "Incident History - Summary",
      "description": "Incident History - Summary",
      "datasource": "datamart",
      "query": "SELECT pr.prison_id         as location,\n       pr.name              as location_name,\n       r.id,\n       r.status,\n       cs.description              as status_description,\n       r.report_reference,\n       ctf.code                    as type,\n       ctf.description             as type_description,\n       r.incident_date_and_time,\n       r.reported_at\nFROM prisons.incidentreporting_report r\n       JOIN prisons.incidentreporting_constant_status cs ON r.status = cs.code\n       JOIN prisons.incidentreporting_constant_type ct ON r.type = ct.code\n       JOIN prisons.incidentreporting_constant_type_family ctf ON ctf.code = ct.family_code\n       JOIN prisons.prisonregister_prison pr ON pr.prison_id = r.location\nWHERE r.status NOT IN ('DUPLICATE', 'NOT_REPORTABLE')",
      "schema": {
        "field": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "report_reference",
            "type": "string"
          },
          {
            "name": "type",
            "type": "string"
          },
          {
            "name": "type_description",
            "type": "string"
          },
          {
            "name": "status_description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "incident_date_and_time",
            "type": "datetime"
          },
          {
            "name": "location",
            "type": "string"
          },
          {
            "name": "location_name",
            "type": "string"
          },
          {
            "name": "reported_at",
            "type": "datetime"
          },
          {
            "name": "reported_by",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "prisons",
      "name": "Prisons",
      "datasource": "datamart",
      "query": "select prison_id, name prison_name FROM prisons.prisonregister_prison p where p.active = true order by name",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "display": "Prison Id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "display": "Prison name",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "types",
      "name": "Incident Types",
      "datasource": "datamart",
      "query": "SELECT code, description FROM prisons.incidentreporting_constant_type_family order by description",
      "schema": {
        "field": [
          {
            "name": "code",
            "display": "Type code",
            "type": "string"
          },
          {
            "name": "description",
            "display": "Type description",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "status",
      "name": "Incident Status",
      "datasource": "datamart",
      "query": "SELECT code, description FROM prisons.incidentreporting_constant_status where code NOT IN ('DUPLICATE', 'NOT_REPORTABLE') order by description",
      "schema": {
        "field": [
          {
            "name": "code",
            "display": "Status code",
            "type": "string"
          },
          {
            "name": "description",
            "display": "Status description",
            "type": "string"
          }
        ]
      }
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "INCIDENT_REPORTS__RO",
                "INCIDENT_REPORTS__RW",
                "INCIDENT_REPORTS__APPROVE"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "caseloads",
      "type": "row-level",
      "action": [
        "location IN (${caseloads}) OR location IS NULL"
      ],
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "exists": [
                "${caseloads}"
              ]
            }
          ]
        }
      ]
    }
  ],
  "report": [
    {
      "id": "116773.RS",
      "name": "DARU Incident Tracker",
      "classification": "OFFICIAL",
      "version": "1.0.0",
      "render": "HTML",
      "dataset": "inc0022-1",
      "feature": [
        {
          "type": "print"
        }
      ],
      "metadata": {
        "hints": [
          "interactive"
        ]
      },
      "specification": {
        "template": "list",
        "field": [
          {
            "name": "$ref:location",
            "display": "Prison",
            "visible": "false",
            "sortable": false,
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "interactive": true,
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 130,
                "returnAsStaticOptions": true,
                "dataset": "prisons",
                "name": "prison_id",
                "display": "prison_name"
              }
            }
          },
          {
            "name": "$ref:location_name",
            "display": "Prison Name",
            "visible": "true",
            "sortable": true,
            "defaultsort": true,
            "sortdirection": "asc"
          },
          {
            "name": "$ref:incident_code",
            "display": "Incident type code",
            "sortable": false,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "interactive": true,
              "mandatory": false,
              "dynamicoptions": {
                "maximumOptions": 60,
                "returnAsStaticOptions": true,
                "dataset": "types",
                "name": "code",
                "display": "description"
              }
            }
          },
          {
            "name": "$ref:incident_type",
            "display": "Incident Type",
            "visible": "true",
            "sortable": true,
            "defaultsort": false
          },
          {
            "name": "$ref:status_code",
            "display": "Status code",
            "sortable": false,
            "visible": "false",
            "defaultsort": false,
            "filter": {
              "type": "multiselect",
              "mandatory": false,
              "interactive": true,
              "dynamicoptions": {
                "maximumOptions": 10,
                "returnAsStaticOptions": true,
                "dataset": "status",
                "name": "code",
                "display": "description"
              }
            }
          },
          {
            "name": "$ref:status",
            "display": "Incident status",
            "sortable": true,
            "visible": "true",
            "defaultsort": false
          },
          {
            "name": "$ref:TOTAL",
            "display": "Number of Incidents",
            "visible": "true",
            "sortable": false,
            "defaultsort": false,
            "formula": "make_url('https://incident-reporting-${env}.hmpps.service.justice.gov.uk/reports?fromDate=${start_date}&toDate=${end_date}&location=${location}&typeFamily=${incident_code}&incidentStatuses=${status_code}',${TOTAL},TRUE)"
          }
        ]
      }
    },
