    {
      "id": "cell-certificate-list-download",
      "name": "Certified cells list (for download)",
      "description": "A flat list of every certified location (wings, landings, spurs and cells) for each prison with an active certification requirement and a current cell certificate, ordered by establishment then location. No sections or totals - intended for downloading to Excel, where the Type column can be used to filter to cells only. All figures are taken from the approved cell certificate.",
      "version": "1.0.0",
      "dataset": "$ref:certificate-cells",
      "render": "HTML",
      "feature": [
        {
