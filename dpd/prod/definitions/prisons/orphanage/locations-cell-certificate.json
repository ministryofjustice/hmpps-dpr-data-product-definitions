{
  "id": "residential-cell-certificate",
  "name": "Cell certificate capacity",
  "description": "Cells and certified capacity for every prison with an active certification requirement and a current cell certificate, taken from the approved cell certificate (the certified snapshot of accommodation). Supports the Capacity Management team.",
  "metadata": {
    "author": "Michael Willis",
    "version": "1.0.0",
    "owner": "Capacity Management team",
    "tags": [
      "DPS",
      "Residential",
      "Capacity"
    ]
  },
  "datasource": [
    {
      "id": "datamart",
      "name": "datamart"
    }
  ],
  "policy": [
    {
      "id": "access",
      "type": "access",
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "match": [
                "${role}",
                "MANAGE_RES_LOCATIONS_OP_CAP",
                "RESI__CERT_VIEWER"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "caseloads",
      "type": "row-level",
      "action": [
        "prison_id IN (${caseloads})"
      ],
      "rule": [
        {
          "effect": "permit",
          "condition": [
            {
              "exists": [
                "${caseloads}"
              ]
            }
          ]
        }
      ]
    }
  ],
  "dataset": [
    {
      "id": "certificate-cells",
      "name": "Cell certificate list",
      "description": "One row per certified location (wings, landings, spurs and cells) for every prison with an active certification requirement and a current cell certificate. Figures are already rolled up in the certificate. The tree is traversed from each certificate's top-level locations down through parent_location_id.",
      "datasource": "dps_locations",
      "query": "WITH RECURSIVE tree AS (\n    SELECT l.id, c.prison_id, c.signed_operation_capacity,\n           l.location_code, l.path_hierarchy, l.local_name, l.cell_mark, l.level,\n           l.location_type, l.in_cell_sanitation,\n           l.certified_normal_accommodation, l.working_capacity, l.max_capacity,\n           l.accommodation_types, l.specialist_cell_types, l.used_for_types\n    FROM prisons.locationsinsideprison_cell_certificate c\n    JOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = c.prison_id\n    JOIN prisons.locationsinsideprison_cell_certificate_location l ON l.cell_certificate_id = c.id\n    WHERE c.current = true AND pc.certification_approval_required = true\n    UNION ALL\n    SELECT l.id, t.prison_id, t.signed_operation_capacity,\n           l.location_code, l.path_hierarchy, l.local_name, l.cell_mark, l.level,\n           l.location_type, l.in_cell_sanitation,\n           l.certified_normal_accommodation, l.working_capacity, l.max_capacity,\n           l.accommodation_types, l.specialist_cell_types, l.used_for_types\n    FROM prisons.locationsinsideprison_cell_certificate_location l\n    JOIN tree t ON l.parent_location_id = t.id\n)\nSELECT\n    t.prison_id,\n    p.name AS prison_name,\n    p.name || '-' || LPAD(SPLIT_PART(t.path_hierarchy, '-', 1), 6, '0') || '-' || LPAD(SPLIT_PART(t.path_hierarchy, '-', 2), 6, '0') || '-' || LPAD(SPLIT_PART(t.path_hierarchy, '-', 3), 6, '0') || '-' || LPAD(SPLIT_PART(t.path_hierarchy, '-', 4), 6, '0') || '-' || LPAD(SPLIT_PART(t.path_hierarchy, '-', 5), 6, '0') || '-' || LPAD(SPLIT_PART(t.path_hierarchy, '-', 6), 6, '0') AS sort_key,\n    t.location_code,\n    t.path_hierarchy,\n    INITCAP(t.local_name) AS local_name,\n    t.cell_mark,\n    t.level,\n    INITCAP(REPLACE(t.location_type, '_', ' ')) AS location_type,\n    (CASE WHEN t.location_type = 'CELL' THEN (CASE WHEN t.in_cell_sanitation THEN 'Yes' ELSE 'No' END) END) AS sanitation,\n    t.certified_normal_accommodation AS cna,\n    t.working_capacity,\n    t.max_capacity,\n    t.signed_operation_capacity,\n    INITCAP(REPLACE(REPLACE(t.accommodation_types, '_', ' '), ',', ', ')) AS accommodation_type,\n    INITCAP(REPLACE(REPLACE(t.specialist_cell_types, '_', ' '), ',', ', ')) AS cell_type,\n    INITCAP(REPLACE(REPLACE(t.used_for_types, '_', ' '), ',', ', ')) AS used_for\nFROM tree t\nJOIN prisons.prisonregister_prison p ON p.prison_id = t.prison_id\nWHERE p.active = true\nORDER BY p.name, t.path_hierarchy",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string"
          },
          {
            "name": "sort_key",
            "type": "string"
          },
          {
            "name": "location_code",
            "type": "string"
          },
          {
            "name": "path_hierarchy",
            "type": "string"
          },
          {
            "name": "local_name",
            "type": "string"
          },
          {
            "name": "cell_mark",
            "type": "string"
          },
          {
            "name": "level",
            "type": "int"
          },
          {
            "name": "location_type",
            "type": "string"
          },
          {
            "name": "sanitation",
            "type": "string"
          },
          {
            "name": "cna",
            "type": "int"
          },
          {
            "name": "working_capacity",
            "type": "int"
          },
          {
            "name": "max_capacity",
            "type": "int"
          },
          {
            "name": "signed_operation_capacity",
            "type": "int"
          },
          {
            "name": "accommodation_type",
            "type": "string"
          },
          {
            "name": "cell_type",
            "type": "string"
          },
          {
            "name": "used_for",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "prisons",
      "name": "Prisons",
      "datasource": "athena_redshift",
      "query": "SELECT DISTINCT c.prison_id, p.name AS prison_name FROM prisons.locationsinsideprison_cell_certificate c JOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = c.prison_id JOIN prisons.prisonregister_prison p ON p.prison_id = c.prison_id WHERE c.current = true AND pc.certification_approval_required = true AND p.active = true ORDER BY p.name",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string",
            "display": "Prison Id"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Prison name"
          }
        ]
      }
    },
    {
      "id": "establishment-summary",
      "name": "Establishment totals",
      "datasource": "redshift",
      "query": "SELECT prison_name,\n       COUNT(*) AS cell_count,\n       SUM(cna) AS cna,\n       SUM(working_capacity) AS working_capacity,\n       SUM(max_capacity) AS max_capacity\nFROM ${tableId}\nWHERE location_type = 'Cell'\nGROUP BY prison_name",
      "schema": {
        "field": [
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          },
          {
            "name": "cna",
            "type": "int",
            "display": "CNA"
          },
          {
            "name": "working_capacity",
            "type": "int",
            "display": "Certified working capacity"
          },
          {
            "name": "max_capacity",
            "type": "int",
            "display": "Max capacity"
          }
        ]
      }
    },
    {
      "id": "grand-total-summary",
      "name": "Grand totals",
      "datasource": "redshift",
      "query": "SELECT COUNT(*) AS cell_count,\n       SUM(cna) AS cna,\n       SUM(working_capacity) AS working_capacity,\n       SUM(max_capacity) AS max_capacity\nFROM ${tableId}\nWHERE location_type = 'Cell'",
      "schema": {
        "field": [
          {
            "name": "cell_count",
            "type": "int",
            "display": "Total number of cells"
          },
          {
            "name": "cna",
            "type": "int",
            "display": "Total CNA"
          },
          {
            "name": "working_capacity",
            "type": "int",
            "display": "Total certified working capacity"
          },
          {
            "name": "max_capacity",
            "type": "int",
            "display": "Total max capacity"
          }
        ]
      }
    },
    {
      "id": "capacity-by-establishment",
      "name": "Certified capacity totals by establishment",
      "datasource": "dps_locations",
      "query": "WITH RECURSIVE tree AS (\n    SELECT l.id, c.prison_id, c.signed_operation_capacity, l.location_type, l.in_cell_sanitation,\n           l.certified_normal_accommodation, l.working_capacity, l.max_capacity\n    FROM prisons.locationsinsideprison_cell_certificate c\n    JOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = c.prison_id\n    JOIN prisons.locationsinsideprison_cell_certificate_location l ON l.cell_certificate_id = c.id\n    WHERE c.current = true AND pc.certification_approval_required = true\n    UNION ALL\n    SELECT l.id, t.prison_id, t.signed_operation_capacity, l.location_type, l.in_cell_sanitation,\n           l.certified_normal_accommodation, l.working_capacity, l.max_capacity\n    FROM prisons.locationsinsideprison_cell_certificate_location l\n    JOIN tree t ON l.parent_location_id = t.id\n)\nSELECT\n    t.prison_id,\n    p.name AS prison_name,\n    COUNT(*) AS number_of_cells,\n    SUM(t.certified_normal_accommodation) AS cna,\n    SUM(t.working_capacity) AS working_capacity,\n    SUM(t.max_capacity) AS max_capacity,\n    MAX(t.signed_operation_capacity) AS signed_operational_capacity,\n    SUM(CASE WHEN t.max_capacity = 1 THEN 1 ELSE 0 END) AS single_cells,\n    SUM(CASE WHEN t.max_capacity = 2 THEN 1 ELSE 0 END) AS double_cells,\n    SUM(CASE WHEN t.in_cell_sanitation THEN 1 ELSE 0 END) AS cells_with_sanitation,\n    SUM(CASE WHEN NOT t.in_cell_sanitation OR t.in_cell_sanitation IS NULL THEN 1 ELSE 0 END) AS cells_without_sanitation\nFROM tree t\nJOIN prisons.prisonregister_prison p ON p.prison_id = t.prison_id\nWHERE p.active = true AND t.location_type = 'CELL'\nGROUP BY t.prison_id, p.name",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "number_of_cells",
            "type": "int",
            "display": "Number of cells"
          },
          {
            "name": "cna",
            "type": "int",
            "display": "CNA"
          },
          {
            "name": "working_capacity",
            "type": "int",
            "display": "Certified working capacity"
          },
          {
            "name": "max_capacity",
            "type": "int",
            "display": "Maximum capacity"
          },
          {
            "name": "signed_operational_capacity",
            "type": "int",
            "display": "Signed operational capacity"
          },
          {
            "name": "single_cells",
            "type": "int",
            "display": "Single cells"
          },
          {
            "name": "double_cells",
            "type": "int",
            "display": "Double cells"
          },
          {
            "name": "cells_with_sanitation",
            "type": "int",
            "display": "Cells with sanitation"
          },
          {
            "name": "cells_without_sanitation",
            "type": "int",
            "display": "Cells without sanitation"
          }
        ]
      }
    },
    {
      "id": "accommodation-type-breakdown",
      "name": "Cells by accommodation type",
      "datasource": "dps_locations",
      "query": "WITH RECURSIVE tree AS (\n    SELECT l.id, c.prison_id, l.location_type, l.accommodation_types AS types\n    FROM prisons.locationsinsideprison_cell_certificate c\n    JOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = c.prison_id\n    JOIN prisons.locationsinsideprison_cell_certificate_location l ON l.cell_certificate_id = c.id\n    WHERE c.current = true AND pc.certification_approval_required = true\n    UNION ALL\n    SELECT l.id, t.prison_id, l.location_type, l.accommodation_types\n    FROM prisons.locationsinsideprison_cell_certificate_location l\n    JOIN tree t ON l.parent_location_id = t.id\n),\nbase AS (\n    SELECT t.prison_id, p.name AS prison_name, split_to_array(t.types, ',') AS arr\n    FROM tree t\n    JOIN prisons.prisonregister_prison p ON p.prison_id = t.prison_id\n    WHERE p.active = true AND t.location_type = 'CELL' AND t.types IS NOT NULL AND t.types <> ''\n)\nSELECT b.prison_id, b.prison_name,\n       INITCAP(REPLACE(TRIM(CAST(a AS VARCHAR)), '_', ' ')) AS accommodation_type,\n       COUNT(*) AS cell_count\nFROM base b, b.arr AS a\nGROUP BY 1, 2, 3",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "accommodation_type",
            "type": "string",
            "display": "Accommodation type"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          }
        ]
      }
    },
    {
      "id": "used-for-breakdown",
      "name": "Cells by used for",
      "datasource": "dps_locations",
      "query": "WITH RECURSIVE tree AS (\n    SELECT l.id, c.prison_id, l.location_type, l.used_for_types AS types\n    FROM prisons.locationsinsideprison_cell_certificate c\n    JOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = c.prison_id\n    JOIN prisons.locationsinsideprison_cell_certificate_location l ON l.cell_certificate_id = c.id\n    WHERE c.current = true AND pc.certification_approval_required = true\n    UNION ALL\n    SELECT l.id, t.prison_id, l.location_type, l.used_for_types\n    FROM prisons.locationsinsideprison_cell_certificate_location l\n    JOIN tree t ON l.parent_location_id = t.id\n),\nbase AS (\n    SELECT t.prison_id, p.name AS prison_name, split_to_array(t.types, ',') AS arr\n    FROM tree t\n    JOIN prisons.prisonregister_prison p ON p.prison_id = t.prison_id\n    WHERE p.active = true AND t.location_type = 'CELL' AND t.types IS NOT NULL AND t.types <> ''\n)\nSELECT b.prison_id, b.prison_name,\n       INITCAP(REPLACE(TRIM(CAST(a AS VARCHAR)), '_', ' ')) AS used_for,\n       COUNT(*) AS cell_count\nFROM base b, b.arr AS a\nGROUP BY 1, 2, 3",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "used_for",
            "type": "string",
            "display": "Used for"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          }
        ]
      }
    },
    {
      "id": "cell-type-breakdown",
      "name": "Cells by cell type",
      "datasource": "dps_locations",
      "query": "WITH RECURSIVE tree AS (\n    SELECT l.id, c.prison_id, l.location_type, l.specialist_cell_types AS types\n    FROM prisons.locationsinsideprison_cell_certificate c\n    JOIN prisons.locationsinsideprison_prison_configuration pc ON pc.prison_id = c.prison_id\n    JOIN prisons.locationsinsideprison_cell_certificate_location l ON l.cell_certificate_id = c.id\n    WHERE c.current = true AND pc.certification_approval_required = true\n    UNION ALL\n    SELECT l.id, t.prison_id, l.location_type, l.specialist_cell_types\n    FROM prisons.locationsinsideprison_cell_certificate_location l\n    JOIN tree t ON l.parent_location_id = t.id\n),\nbase AS (\n    SELECT t.prison_id, p.name AS prison_name, split_to_array(t.types, ',') AS arr\n    FROM tree t\n    JOIN prisons.prisonregister_prison p ON p.prison_id = t.prison_id\n    WHERE p.active = true AND t.location_type = 'CELL' AND t.types IS NOT NULL AND t.types <> ''\n)\nSELECT b.prison_id, b.prison_name,\n       INITCAP(REPLACE(TRIM(CAST(a AS VARCHAR)), '_', ' ')) AS cell_type,\n       COUNT(*) AS cell_count\nFROM base b, b.arr AS a\nGROUP BY 1, 2, 3",
      "schema": {
        "field": [
          {
            "name": "prison_id",
            "type": "string"
          },
          {
            "name": "prison_name",
            "type": "string",
            "display": "Establishment"
          },
          {
            "name": "cell_type",
            "type": "string",
            "display": "Cell type"
          },
          {
            "name": "cell_count",
            "type": "int",
            "display": "Number of cells"
          }
        ]
      }
    }
  ],
